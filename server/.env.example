PORT=4000
CORS_ORIGIN=http://localhost:3000,https://jetsurf-crimea.ru
TELEGRAM_BOT_TOKEN=
# Базовый URL Telegram API. Для ретранслятора укажите, например, http://104.128.131.70
TELEGRAM_API_BASE=https://api.telegram.org
# Числовой Telegram user id (узнать у @userinfobot). Через запятую — несколько владельцев.
TELEGRAM_OWNER_IDS=
# Опционально: дополнительный получатель заявок (как раньше). Владельцы из TELEGRAM_OWNER_IDS тоже получают.
TELEGRAM_CHAT_ID=
# Только для локальной отладки: заявка без Telegram (в продакшене не включать).
# ALLOW_LEADS_WITHOUT_TELEGRAM=1

# --- Настройки только для второго VPS (ретранслятора) ---
